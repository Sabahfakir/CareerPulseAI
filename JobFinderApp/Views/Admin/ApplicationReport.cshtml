
@{
    ViewBag.Title = "Application Report";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}


<link href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📊 Application Report</h2>
    </div>

    <div class="card-box mb-4">
        <h5>Filter Applications</h5>

        <div class="row">
            <div class="col-md-4">
                <select id="status" class="form-control">
                    <option value="">All Status</option>
                    <option>Pending</option>
                    <option>Shortlisted</option>
                    <option>Rejected</option>
                </select>
            </div>

            <div class="col-md-4">
                <button id="btnFilter" class="btn btn-primary w-100">Filter</button>
            </div>
        </div>
    </div>

    <div class="card-box">
        <table id="appTable" class="display">
            <thead>
                <tr>
                    <th>Candidate</th>
                    <th>Job</th>
                    <th>Company</th>
                    @*<th>Date</th>*@
                    <th>Status</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

<script>
var table = $('#appTable').DataTable({
    ajax: {
        url: '@Url.Action("GetApplications","Admin")',
        data: function (d) {
            d.status = $('#status').val();
        }
    },
    columns: [
        { data: 'Candidate' },
        { data: 'Job' },
        { data: 'Company' },
       /* { data: 'AppliedDate' },*/
        {
            data: 'Status',
            render: function (d) {
                return `<span class="badge bg-info">${d}</span>`;
            }
        }
    ]
     ,"pageLength": 5,
    "lengthMenu": [5, 10, 20],
    "dom": 'Bfrtip',
    "buttons": ['copy', 'excel', 'csv', 'pdf']
});

$('#btnFilter').click(() => table.ajax.reload());
</script>
