
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Candidate Report";
}



<link href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" rel="stylesheet" />
<link href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.dataTables.min.css" rel="stylesheet" />

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>

<style>
    .card-box {
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        padding: 20px;
        background: #fff;
    }

    .filter-box input {
        border-radius: 8px;
    }

    .btn-custom {
        border-radius: 8px;
    }

    table.dataTable thead {
        background-color: #343a40;
        color: white;
    }

    h2 {
        font-weight: 600;
    }
</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📊 Candidate Report</h2>
    </div>

    <!-- FILTER CARD -->
  

    <!-- TABLE CARD -->
    <div class="card-box">
        <table id="candidateTable" class="display nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Skills</th>
                    <th>Experience (Years)</th>
                </tr>
            </thead>
        </table>
    </div>

</div>

<script>
    var table;

    $(document).ready(function () {

        table = $('#candidateTable').DataTable({
            "ajax": {
                "url": '@Url.Action("GetCandidates", "Admin")',
                "data": function (d) {
                    d.skill = $('#skill').val();
                    d.minExp = $('#minExp').val();
                    d.maxExp = $('#maxExp').val();
                }
            },
            "columns": [
                { "data": "Name" },
                { "data": "Email" },
                {
                    "data": "Skills",
                    "render": function (data) {
                        return '<span class=\"badge bg-info text-dark\">' + data + '</span>';
                    }
                },
                {
                    "data": "Experience",
                    "render": function (data) {
                        return '<span class=\"badge bg-success\">' + data + ' yrs</span>';
                    }
                }
            ],
            "pageLength": 5,
            "lengthMenu": [5, 10, 20],
            "dom": 'Bfrtip',
            "buttons": ['copy', 'excel', 'csv', 'pdf']
        });

        $('#btnFilter').click(function () {
            table.ajax.reload();
        });

    });
</script>