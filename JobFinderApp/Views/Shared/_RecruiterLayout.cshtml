<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recruiter Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="~/Template/css/canStyle.css" rel="stylesheet" />
  
</head>
<body>

    <div class="sidebar" id="sidebar">
        <h4>CareerPulse AI</h4>

        <div class="toggle-btn" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </div>
        <hr>
        <a href="/Recruiter/Index">
            <i class="fas fa-tachometer-alt"></i>
            <span>Dashboard</span>
        </a>

        <a href="/Recruiter/PostJob">
            <i class="fas fa-plus-circle"></i>
            <span>Post Jobs</span>
        </a>

        <a href="/Recruiter/MyPostedJobs">
            <i class="fas fa-briefcase"></i>
            <span>My Posted Jobs</span>
        </a>

        <a href="/Recruiter/RecruiterProfile">
            <i class="fas fa-user-tie"></i>
            <span>Profile</span>
        </a>

        <a href="/Registration/Logout">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </a>
    </div>

    <div class="main-content" id="mainContent">
        @RenderBody()
    </div>


    <script>
        function toggleSidebar() {
            document.getElementById("sidebar").classList.toggle("collapsed");
            document.getElementById("mainContent").classList.toggle("expanded");
        }
    </script>
</body>
</html>

