<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Candidate Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="~/Template/css/canStyle.css" rel="stylesheet" />
</head>

<body>

    <div class="sidebar" id="sidebar">
        <h4>CareerPulse AI</h4>

        <div class="toggle-btn" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </div>

        <a href="/Candidate/Index" class="active">
            <i class="fas fa-tachometer-alt"></i>
            <span>Dashboard</span>
        </a>

        <a href="/Home/Jobs">
            <i class="fas fa-search"></i>
            <span>Find Jobs</span>
        </a>

        <a href="/Candidate/MyApplications">
            <i class="fas fa-file-alt"></i>
            <span>Applications</span>
        </a>

        <a href="/Candidate/SavedJobs">
            <i class="fas fa-bookmark"></i>
            <span>Saved Jobs</span>
        </a>

        <a href="/Candidate/UserProfile">
            <i class="fas fa-user"></i>
            <span>Profile</span>
        </a>

        <a href="/Resume/ResumeBuilder">
            <i class="fas fa-file-signature"></i>
            <span>Resume Builder</span>
        </a>

        <a href="/Resume/Index">
            <i class="fas fa-chart-line"></i>
            <span>Resume Analyzer</span>
        </a>

        <a href="/Resume/MyResumes">
            <i class="fas fa-folder-open"></i>
            <span>My Resumes</span>
        </a>

        <a href="/Registration/Logout">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </a>
    </div>

    <!-- Main Content -->
    <div class="main-content" id="mainContent">
        @RenderBody()
    </div>

    <script>
    function toggleSidebar() {
        document.getElementById("sidebar").classList.toggle("collapsed");
        document.getElementById("mainContent").classList.toggle("expanded");
    }
    </script>

</body>
</html>