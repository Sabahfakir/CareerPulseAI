@model  List<JobFinderApp.Models.Job>
    @using JobFinderApp.Helper;
@{
    ViewBag.Title = "Jobs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header End -->
<div class="container-fliud py-5 bg-dark page-header mb-5">
    <div class="container my-5 pt-5 pb-4">
        <h1 class="display-3 text-white mb-3 animated slideInDown">Jobs</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb text-uppercase">
                <li class="breadcrumb-item"><a href="#">Home</a></li>
                <li class="breadcrumb-item text-white active" aria-current="page">Jobs</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Header End -->

<div class="container mt-5">
    <h2 class="mb-4 text-center">Latest Job Openings</h2>

    <div class="row">
        @if (Model.Count > 0)
        {
            foreach (var job in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm p-3">
                        <h4>@job.JobTitle</h4>
                        <p><strong>Company:</strong> @job.Recruiter.CompanyName</p>
                        <p><strong>Location:</strong> @job.Location</p>
                        <p><strong>Type:</strong> @job.JobType</p>
                        <p><strong>Experience:</strong> @job.ExperienceRequired</p>
                        <p><strong>Salary:</strong> @job.SalaryRange</p>
                        <p>
                            <strong>Deadline:</strong>
                            @DateHelper.GetDeadlineText(job.ApplicationDeadline)
                        </p>

                        <div class="d-flex gap-2 mt-auto">


                            <a href="@Url.Action("JobDetails", "Home", new { id = job.JobId })" class="btn btn-primary">
                                View Details
                            </a>
                            <a href="@Url.Action("SaveJob", "Home", new { jobId = job.JobId })"
                               class="btn btn-outline-primary">
                                <i class="fa fa-bookmark"></i> 
                            </a>
                        </div>
                         </div>
                    </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <p>No jobs available right now.</p>
            </div>
        }
  
    </div>
</div>
