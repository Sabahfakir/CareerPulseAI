@model JobFinderApp.Models.Contact 
@{
    ViewBag.Title = "CareerPulse AI | Contact";

}

<!-- Header End -->
<div class="container-fliud py-5 bg-dark page-header mb-5">
    <div class="container my-5 pt-5 pb-4">
        <h1 class="display-3 text-white mb-3 animated slideInDown">Contact</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb text-uppercase">
                <li class="breadcrumb-item"><a href="#">Home</a></li>

                <li class="breadcrumb-item text-white active" aria-current="page">Contact</li>
            </ol>
        </nav>
    </div>
</div>
<!-- Header End -->

<div class="container-fliud py-5">
    <div class="container shadow-lg py-5 bg-white">
        <h1 class="text-center mb-5 wow fadeInUp" data-wow-delay="0.1s">Contact For Any Query</h1>
        <div class="row g-4">
            <div class=" d-flex justify-content-center">
                <div class="col-md-10">
                    <div class="wow fadeInUp" data-wow-delay="0.5s">
                        <div class="col-md-12">

                            @using (Html.BeginForm("Contact", "Home", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()

                                <div class="row g-3">

                                    <div class="col-md-6">
                                        <div class="form-floating">
                                            @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Your Name" })
                                            <label>Your Name</label>
                                            @Html.ValidationMessageFor(m => m.Name)
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-floating">
                                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Your Email", type = "email" })
                                            <label>Your Email</label>
                                            @Html.ValidationMessageFor(m => m.Email)
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="form-floating">
                                            @Html.TextBoxFor(m => m.Subject, new { @class = "form-control", placeholder = "Subject" })
                                            <label>Subject</label>
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <div class="form-floating">
                                            @Html.TextAreaFor(m => m.Message, new { @class = "form-control", style = "height:150px", placeholder = "Message" })
                                            <label>Message</label>
                                            @Html.ValidationMessageFor(m => m.Message)
                                        </div>
                                    </div>

                                    <div class="col-12">
                                        <button class="btn btn-primary w-100 py-3" type="submit">
                                            Send Message
                                        </button>
                                    </div>

                                </div>
                            }

                            @if (ViewBag.Message != null)
                            {
                                <div class="alert alert-success mt-3">
                                    @ViewBag.Message
                                </div>
                            }
                        </div>
                       
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>