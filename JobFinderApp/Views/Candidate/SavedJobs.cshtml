@model List<JobFinderApp.Models.Job>
@{
    ViewBag.Title = "Saved Jobs";
    Layout = "~/Views/Shared/_CandidateLayout.cshtml";
}




<div class="container mt-5">
    <h2 class="mb-4 text-center">Saved Jobs</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        @if (Model.Count > 0)
        {
            foreach (var job in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow p-3">
                        <h4>@job.JobTitle</h4>

                        <p><strong>Company:</strong> @job.Recruiter.CompanyName</p>
                        <p><strong>Location:</strong> @job.Location</p>
                        <p><strong>Type:</strong> @job.JobType</p>
                        <p><strong>Salary:</strong> @job.SalaryRange</p>

                        <div class="d-flex gap-2">
                            <a href="@Url.Action("JobDetails", "Home", new { id = job.JobId })"
                               class="btn btn-primary">
                                View Details
                            </a>

                            <a href="@Url.Action("RemoveSavedJob", "Candidate", new { jobId = job.JobId })"
                               class="btn btn-danger">
                                Remove
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center">
                <p>No saved jobs found.</p>
            </div>
        }
    </div>
</div>

