@model JobFinderApp.ViewModels.CandidateProfileVm
@{
    ViewBag.Title = "UserProfile";
    Layout = "~/Views/Shared/_CandidateLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .profile-banner {
        height: 200px;
        background-color: #00B074;
        border-radius: 10px 10px 0 0;
    }

    .profile-img {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        border: 5px solid white;
        margin-top: -70px;
        object-fit: cover;
        background: #fff;
    }

    .card-section {
        border-radius: 10px;
        margin-bottom: 20px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .skill-badge {
        background: #e7f3ff;
        color: #0d6efd;
        padding: 6px 12px;
        border-radius: 20px;
        margin: 5px;
        display: inline-block;
    }
</style>

<div class="col-md-12 p-4">

    <!-- Profile Header -->
    <div class="card shadow">
        <div class="profile-banner"></div>

        <div class="text-center p-3">
            <img src="@(string.IsNullOrEmpty(Model.ProfileImagePath) ? "/Content/images/default-user.png" : Model.ProfileImagePath)"
                 class="profile-img" />

            <h4 class="mt-3">@Model.FullName</h4>
            <p class="text-muted">@Model.Email</p>
            <p>@Model.Mobile</p>

            <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#profileModal">
                Edit Profile
            </button>
        </div>
    </div>

    <!-- About -->
    <div class="card shadow p-3 card-section mt-3">
        <div class="section-header">
            <h5>About</h5>
        </div>
        <p class="text-muted mt-2">
            @(string.IsNullOrEmpty(Model.About) ? "Add a summary about yourself..." : Model.About)
        </p>
    </div>

    <!-- Skills -->
    <div class="card shadow p-3 card-section">
        <div class="section-header">
            <h5>Skills</h5>
        </div>

        <div class="mt-2">
            @if (!string.IsNullOrEmpty(Model.Skills))
            {
                var skills = Model.Skills.Split(',');
                foreach (var skill in skills)
                {
                    <span class="skill-badge">@skill.Trim()</span>
                }
            }
            else
            {
                <p class="text-muted">No skills added</p>
            }
        </div>
    </div>

   

    <!-- Experience Details -->
    <div class="card shadow p-3 card-section">
        <div class="section-header">
            <h5>Experience Details</h5>
            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#experienceModal">
                Add
            </button>
        </div>

        @if (Model.ExperienceList != null && Model.ExperienceList.Any())
        {
            foreach (var exp in Model.ExperienceList)
            {
                <div class="mt-2">
                    <h6>@exp.JobRole - @exp.CompanyName</h6>
                    <small class="text-muted">@exp.Years years</small>
                    <p>@exp.Description</p>
                </div>
                <hr />
            }
        }
        else
        {
            <p class="text-muted">No experience added</p>
        }
    </div>

    <!-- Education -->
    <div class="card shadow p-3 card-section">
        <div class="section-header">
            <h5>Education</h5>
            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#educationModal">
                Add
            </button>
        </div>

        @if (Model.EducationList != null && Model.EducationList.Any())
        {
            foreach (var edu in Model.EducationList)
            {
                <div class="mt-2">
                    <h6>@edu.Degree - @edu.Institution</h6>
                    <small class="text-muted">@edu.Year</small>
                </div>
                <hr />
            }
        }
        else
        {
            <p class="text-muted">No education added</p>
        }
    </div>

    <!-- Resume -->
    <div class="card shadow p-3 card-section">
        <div class="section-header">
            <h5>Resume</h5>
        </div>

        @if (!string.IsNullOrEmpty(Model.ResumePath))
        {
            <a href="@Model.ResumePath" target="_blank" class="btn btn-outline-primary mt-2">
                View Resume
            </a>
        }
        else
        {
            <p class="text-muted">No resume uploaded</p>
        }
    </div>

</div>


<!-- PROFILE MODAL -->
<div class="modal fade" id="profileModal">
    <div class="modal-dialog">
        <div class="modal-content">

            @using (Html.BeginForm("SaveProfile", "Candidate", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <div class="modal-header">
                    <h5>Edit Profile</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body text-center">

                    <!-- Current Profile Image -->
                    <img src="@(string.IsNullOrEmpty(Model.ProfileImagePath) ? "/Content/images/default-user.png" : Model.ProfileImagePath)"
                         class="profile-img mb-3" style="width:100px;height:100px;" />

                    <!-- Upload Profile Image -->
                    <label class="form-label">Upload Profile Photo</label>
                    <input type="file" name="ProfileImage" class="form-control mb-3" />

                    @Html.TextBoxFor(m => m.FullName, new { @class = "form-control mb-2", placeholder = "Full Name" })
                    @Html.TextBoxFor(m => m.Mobile, new { @class = "form-control mb-2", placeholder = "Mobile" })
                    @Html.TextAreaFor(m => m.Skills, new { @class = "form-control mb-2", placeholder = "Skills" })
                    @Html.TextAreaFor(m => m.About, new { @class = "form-control mb-2", placeholder = "About" })

                    <label>Upload Resume</label>
                    <input type="file" name="ResumeFile" class="form-control" />
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- EXPERIENCE MODAL -->
<div class="modal fade" id="experienceModal">
    <div class="modal-dialog">
        <div class="modal-content">

            @using (Html.BeginForm("AddExperience", "Candidate", FormMethod.Post))
            {
                <div class="modal-header">
                    <h5>Add Experience</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="text" name="CompanyName" placeholder="Company" class="form-control mb-2" />
                    <input type="text" name="JobRole" placeholder="Role" class="form-control mb-2" />
                    <input type="number" name="Years" placeholder="Years" class="form-control mb-2" />
                    <textarea name="Description" placeholder="Description" class="form-control"></textarea>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Add</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- EDUCATION MODAL -->
<div class="modal fade" id="educationModal">
    <div class="modal-dialog">
        <div class="modal-content">

            @using (Html.BeginForm("AddEducation", "Candidate", FormMethod.Post))
            {
                <div class="modal-header">
                    <h5>Add Education</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="text" name="Degree" placeholder="Degree" class="form-control mb-2" />
                    <input type="text" name="Institution" placeholder="Institution" class="form-control mb-2" />
                    <input type="text" name="Year" placeholder="Year" class="form-control mb-2" />
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Add</button>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>