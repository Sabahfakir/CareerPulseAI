<div class="container-fliud py-5">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.1s">
                <div class="row g-0 about-bg rounded overflow-hidden">
                    <div class="">
                        <img class="img-fluid w-100" src="~/Template/img/a1.jpg">
                    </div>
                </div>
            </div>
            <div class="col-lg-6 wow fadeIn" data-wow-delay="0.5s">
                <h1 class="mb-4">Empowering Careers, Sourcing Excellence</h1>
                <p class="mb-4">Our Online Job Portal is a modern recruitment platform designed to simplify the job search and hiring process. We provide a centralized system where job seekers can discover opportunities and employers can find the right talent efficiently.</p>
                <p><i class="fa fa-check text-primary me-3"></i>Easy Job Search</p>
                <p><i class="fa fa-check text-primary me-3"></i>Real Time Updates</p>
                <p><i class="fa fa-check text-primary me-3"></i>Matching skills with opportunities</p>
                <a class="btn btn-primary py-3 px-5 mt-3" href="">Read More</a>
            </div>
        </div>
    </div>
</div>

