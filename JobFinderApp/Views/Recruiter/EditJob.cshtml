@model JobFinderApp.Models.Job

@{
    ViewBag.Title = "Edit Job";
    Layout = "~/Views/Shared/_RecruiterLayout.cshtml";
}

<div class="container mt-5">
    <h2>Edit Job</h2>

    <!-- ✅ UPDATE FORM -->
    @using (Html.BeginForm("EditJob", "Recruiter", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.JobId)

        <div class="mb-3">
            <label>Job Title</label>
            @Html.TextBoxFor(m => m.JobTitle, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Location</label>
            @Html.TextBoxFor(m => m.Location, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Job Type</label>
            @Html.TextBoxFor(m => m.JobType, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Experience</label>
            @Html.TextBoxFor(m => m.ExperienceRequired, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Salary</label>
            @Html.TextBoxFor(m => m.SalaryRange, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Description</label>
            @Html.TextAreaFor(m => m.JobDescription, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Responsibilities</label>
            @Html.TextAreaFor(m => m.Responsibilities, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Required Skills</label>
            @Html.TextBoxFor(m => m.Skills, new { @class = "form-control" })
        </div>

        <div class="mb-3">
            <label>Deadline</label>
            @Html.TextBoxFor(m => m.ApplicationDeadline, new { @type = "date", @class = "form-control" })
        </div>

        <!-- LEFT BUTTONS -->
        <div class="mt-4">
            <button type="submit" class="btn btn-success">
                Update Job
            </button>

            <a href="@Url.Action("MyPostedJobs", "Recruiter")"
               class="btn btn-secondary ms-2">
                Cancel
            </a>
        </div>
    }

    <!-- ✅ DELETE FORM (SEPARATE - IMPORTANT) -->
    <div class="mt-3 text-end">
        @using (Html.BeginForm("DeleteJob", "Recruiter", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.JobId" />

            <button type="submit"
                    class="btn btn-danger"
                    onclick="return confirm('Are you sure you want to delete this job?');">
                Delete Job
            </button>
        }
    </div>
</div>