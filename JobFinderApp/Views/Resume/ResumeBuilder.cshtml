@{
    ViewBag.Title = "Resume Builder";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    #resumePreview {
        width: 100%;
        max-width: 800px;
        margin: auto;
        padding: 30px;
        background: #fff;
        font-family: 'Segoe UI', sans-serif;
        font-size: 14px;
        box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    .header {
        text-align: center;
        border-bottom: 2px solid #000;
        margin-bottom: 10px;
    }

    .section h4 {
        border-bottom: 1px solid #ccc;
        padding-bottom: 5px;
        margin-bottom: 10px;
        color: #2c3e50;
    }

    #p_skills li {
        margin-bottom: 5px;
    }
</style>

<div class="container-fluid mt-4">
    <div class="row">

        <!-- FORM -->
        <div class="col-md-6">
            <div class="card p-3 shadow">

                <h4>Resume Builder</h4>
                <!-- TABS -->
                <ul class="nav nav-tabs mt-3" id="resumeTabs">
                    <li class="nav-item">
                        <a class="nav-link active" data-bs-toggle="tab" href="#tab1">Personal</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tab2">Summary & Skills</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tab3">Experience</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tab4">Education</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" data-bs-toggle="tab" href="#tab5">Projects</a>
                    </li>
                </ul>

                <!-- TAB CONTENT -->
                <div class="tab-content mt-3">

                    <div class="tab-pane fade show active" id="tab1">
                        <h5 class="mt-3">Personal Details</h5>

                        <input id="name" class="form-control mb-2" placeholder="Full Name" />
                        <input id="email" class="form-control mb-2" placeholder="Email" />
                        <input id="phone" class="form-control mb-2" placeholder="Phone" />
                        <input type="date" id="dob" class="form-control mb-2" />

                        <input id="city" class="form-control mb-2" placeholder="City" />
                        <input id="state" class="form-control mb-2" placeholder="State" />
                        <input id="country" class="form-control mb-2" placeholder="Country" />
                        <input id="zip" class="form-control mb-2" placeholder="Zip Code" />
                    </div>
                    <div class="tab-pane fade" id="tab2">

                        <textarea id="summary" class="form-control mb-2" placeholder="Summary"></textarea>

                        <textarea id="skills" class="form-control mb-2"
                                  placeholder="e.g. ASP.NET MVC, C#, SQL, .NET Core"></textarea>
                        <small id="skillError" class="text-danger"></small>
                    </div>

                    <!-- EXPERIENCE -->
                    <div class="tab-pane fade" id="tab3">
                        <div id="experienceSection">
                            <h6>Experience</h6>
                            <select id="userType" class="form-control mb-2">
                                <option value="">Select Type</option>
                                <option value="fresher">Fresher</option>
                                <option value="experienced">Experienced</option>
                            </select>

                            <input id="jobTitle" class="form-control mb-2" placeholder="Job Title" />
                            <input id="company" class="form-control mb-2" placeholder="Company Name" />
                            <input id="expLocation" class="form-control mb-2" placeholder="Location" />

                            <div class="d-flex gap-2 mb-2">
                                <input type="date" id="startDate" class="form-control" />
                                <input type="date" id="endDate" class="form-control" />
                            </div>

                            <label>
                                <input type="checkbox" id="isCurrent" /> Currently Working Here
                            </label>

                            <textarea id="expDesc" class="form-control mb-2"
                                      placeholder="Describe your work (use bullet points)"></textarea>

                            <button onclick="addExperience()" class="btn btn-secondary w-100 mb-2">
                                Add Experience
                            </button>

                            <ul id="experienceList" class="list-group mb-2"></ul>

                        </div>

                        <!-- Message for freshers -->
                        <div id="fresherMessage" class="text-muted" style="display:none;">
                            <p>No experience required for freshers.</p>
                        </div>

                    </div>

                    <!-- EDUCATION -->
                    <div class="tab-pane fade" id="tab4">

                        <!-- ✅ EDUCATION (CORRECT PLACE) -->
                        <h6>Education</h6>

                        <input id="secondary" class="form-control mb-2" placeholder="Secondary (10th)" />
                        <input id="secondarySchool" class="form-control mb-2" placeholder="School Name" />
                        <input id="secondaryYear" class="form-control mb-2" placeholder="Year" />
                        <input id="secondaryScore" class="form-control mb-2" placeholder="Score" />

                        <input id="higher" class="form-control mb-2" placeholder="Higher Secondary (12th)" />
                        <input id="higherCollege" class="form-control mb-2" placeholder="College Name" />
                        <input id="higherYear" class="form-control mb-2" placeholder="Year" />
                        <input id="higherScore" class="form-control mb-2" placeholder="Score" />

                        <input id="graduation" class="form-control mb-2" placeholder="Graduation" />
                        <input id="gradCollege" class="form-control mb-2" placeholder="University Name" />
                        <input id="gradYear" class="form-control mb-2" placeholder="Year" />
                        <input id="gradScore" class="form-control mb-2" placeholder="CGPA" />

                        <input id="postgrad" class="form-control mb-2" placeholder="Post Graduation" />
                        <input id="postgradCollege" class="form-control mb-2" placeholder="University Name" />
                        <input id="postgradYear" class="form-control mb-2" placeholder="Year" />
                        <input id="postgradScore" class="form-control mb-2" placeholder="CGPA" />
                    </div>

                    <!-- PROJECTS -->
                    <div class="tab-pane fade" id="tab5">

                        <!-- PROJECT -->
                        <h6>Projects</h6>
                        <input id="projectTitle" class="form-control mb-2" placeholder="Project Title" />
                        <input id="projectTech" class="form-control mb-2" placeholder="Technologies" />
                        <textarea id="projectDesc" class="form-control mb-2" placeholder="Description"></textarea>

                        <button onclick="addProject()" class="btn btn-info w-100 mb-2">Add Project</button>
                        <ul id="projectList" class="list-group mb-2"></ul>
                    </div>

                </div>
                <button onclick="generateSummary()" class="btn btn-primary w-100 mb-2">
                    🤖 Generate Summary
                </button>
                <button onclick="saveResume()" class="btn btn-warning w-100 mb-2">💾 Save Resume</button>
                <button onclick="downloadPDF()" class="btn btn-success w-100">📄 Download PDF</button>

            </div>
                </div>

        <!-- PREVIEW -->
        <div class="col-md-6">
            <div id="resumePreview">

                <!-- HEADER -->
                <div style="border-bottom:2px solid #2c3e50; padding-bottom:10px; margin-bottom:15px;">
                    <h2 id="p_name" style="margin:0; color:#2c3e50;"></h2>
                    <p id="p_contact" style="margin:2px 0;"></p>
                    <p id="p_address" style="margin:0; font-size:13px;"></p>
                </div>

                <!-- SUMMARY -->
                <div class="section">
                    <h4>Professional Summary</h4>
                    <p id="p_summary"></p>
                </div>

                <!-- SKILLS -->
                <div class="section">
                    <h4>Technical Skills</h4>
                    <ul id="p_skills" style="columns:2;"></ul>
                </div>

                <!-- EXPERIENCE -->
                <div class="section">
                    <h4>Experience</h4>
                    <div id="p_experience"></div>
                </div>

                <!-- EDUCATION -->
                <div class="section">
                    <h4>Education</h4>
                    <div id="p_education"></div>
                </div>

                <!-- PROJECTS -->
                <div class="section">
                    <h4>Projects</h4>
                    <div id="p_projects"></div>
                </div>

            </div>
        </div>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    let projects = [];

    // LIVE PREVIEW
    $("input, textarea").on("input", function () {

        $("#p_name").text($("#name").val());

        $("#p_contact").text(
            $("#email").val() + " | " +
            $("#phone").val() + " |DOB: " + formatDate($("#dob").val())
        );

        $("#p_address").text(
            $("#city").val() + ", " +
            $("#state").val() + ", " +
            $("#country").val() + " - " +
            $("#zip").val()
        );

        $("#p_summary").text($("#summary").val());
       

        // ✅ SKILLS FIXED
        let result = validateSkills();

        $("#p_skills").html("");

        if (!result.isValid) {
            $("#skillError").text(result.error);
        } else {
            $("#skillError").text("");

            result.skills.forEach(skill => {
                $("#p_skills").append(`<li>${skill}</li>`);
            });
        }

        // ✅ EDUCATION FIXED
        $("#p_education").html("");

        function addEdu(deg, col, yr, sc) {
            if (deg) {
                $("#p_education").append(`
<div style="margin-bottom:10px;">
    <b>${deg}</b><br />
    <span>${col}</span><br />
    <small>${yr} | Score: ${sc}</small>
</div>
            `);
            }
        }

        addEdu($("#secondary").val(), $("#secondarySchool").val(), $("#secondaryYear").val(), $("#secondaryScore").val());
        addEdu($("#higher").val(), $("#higherCollege").val(), $("#higherYear").val(), $("#higherScore").val());
        addEdu($("#graduation").val(), $("#gradCollege").val(), $("#gradYear").val(), $("#gradScore").val());
        addEdu($("#postgrad").val(), $("#postgradCollege").val(), $("#postgradYear").val(), $("#postgradScore").val());

        renderExperience();
    });

    // GENERATE SUMMARY
    function generateSummary() {
        $.post('/Resume/GenerateSummary', {
            name: $("#name").val(),
            skills: $("#skills").val(),
            experience: JSON.stringify(experiences),
            education: $("#graduation").val()
        }, function (res) {
            if (res.success) {
                $("#summary").val(res.summary);
                $("#p_summary").text(res.summary);
            }
        });
    }

    let experiences = [];

    function addExperience() {

        let exp = {
            JobTitle: $("#jobTitle").val(),
            CompanyName: $("#company").val(),
            Location: $("#expLocation").val(),
            StartDate: $("#startDate").val(),
            EndDate: $("#endDate").val(),
            IsCurrent: $("#isCurrent").is(":checked"),
            Description: $("#expDesc").val()
        };

        if (!exp.JobTitle || !exp.CompanyName) {
            alert("Job Title and Company are required");
            return;
        }

        experiences.push(exp);

        $("#experienceList").append(
            `<li class="list-group-item">${exp.JobTitle} - ${exp.CompanyName}</li>`
        );

        
        renderExperience();

        $("#jobTitle, #company, #expLocation, #startDate, #endDate, #expDesc").val("");
        $("#isCurrent").prop("checked", false);
    }
    // PROJECTS
    function addProject() {
        let p = {
            title: $("#projectTitle").val(),
            tech: $("#projectTech").val(),
            desc: $("#projectDesc").val()
        };

        if (!p.title || !p.desc) {
            alert("Enter project details");
            return;
        }

        projects.push(p);
        $("#projectList").append(`<li class="list-group-item">${p.title}</li>`);
        renderProjects();

        $("#projectTitle, #projectTech, #projectDesc").val("");
    }

    function renderProjects() {
        $("#p_projects").html("");

        projects.forEach(p => {
            $("#p_projects").append(`
<div style="margin-bottom:10px;">
    <b>${p.title}</b><br />
    <small>${p.tech}</small><br />
    <span>${p.desc}</span>
</div>
        `);
        });
    }



    // SAVE
    function saveResume() {

        let educationList = [
            {
                Degree: $("#secondary").val(),
                Institution: $("#secondarySchool").val(),
                Year: $("#secondaryYear").val(),
                Score: $("#secondaryScore").val()
            },
            {
                Degree: $("#higher").val(),
                Institution: $("#higherCollege").val(),
                Year: $("#higherYear").val(),
                Score: $("#higherScore").val()
            },
            {
                Degree: $("#graduation").val(),
                Institution: $("#gradCollege").val(),
                Year: $("#gradYear").val(),
                Score: $("#gradScore").val()
            },
            {
                Degree: $("#postgrad").val(),
                Institution: $("#postgradCollege").val(),
                Year: $("#postgradYear").val(),
                Score: $("#postgradScore").val()
            }
        ];

        $.ajax({
            url: '/Resume/SaveResume',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({
                FullName: $("#name").val(),
                Email: $("#email").val(),
                Phone: $("#phone").val(),
                Summary: $("#summary").val(),
                Skills: $("#skills").val().split(","),
                Experience: $("#experience").val(),
                City: $("#city").val(),
                State: $("#state").val(),
                Country: $("#country").val(),
                ZipCode: $("#zip").val(),
                DOB: $("#dob").val(),
                EducationList: educationList,
                Projects: projects
            }),
            success: function (res) {
                alert(res.message);
            }
        });
    }

    // ✅ PDF FIX (IMPORTANT)
    async function downloadPDF() {

        const element = document.getElementById("resumePreview");
        renderExperience();
        // FORCE re-render
        await new Promise(resolve => setTimeout(resolve, 500));

        html2pdf().set({
            margin: 0,
            filename: 'Resume.pdf',
            image: { type: 'jpeg', quality: 1 },
            html2canvas: {
                scale: 2,
                scrollY: 0,
                useCORS: true
            },
            jsPDF: {
                unit: 'mm',
                format: 'a4',
                orientation: 'portrait'
            }
        }).from(element).save();
    }

    function formatDate(dateString) {
        if (!dateString) return "";

        let date = new Date(dateString);

        return date.toLocaleDateString("en-GB", {
            day: "2-digit",
            month: "short",
            year: "numeric"
        });
    }

    // inside input event:
    $("#p_dob").text(formatDate($("#dob").val()));

    function validateSkills() {

        let raw = $("#skills").val();
        let skillArray = raw.split(",");

        let cleanSkills = [];
        let errors = [];

        const regex = /^[a-zA-Z0-9+#. ]+$/;

        skillArray.forEach(s => {
            let skill = s.trim();

            if (!skill) return;

            if (skill.length < 2) {
                errors.push(`"${skill}" too short`);
                return;
            }

            if (!regex.test(skill)) {
                errors.push(`"${skill}" invalid characters`);
                return;
            }

            if (cleanSkills.includes(skill.toLowerCase())) {
                errors.push(`"${skill}" duplicate`);
                return;
            }

            cleanSkills.push(skill);
        });

        if (cleanSkills.length > 20) {
            errors.push("Maximum 20 skills allowed");
        }

        return {
            isValid: errors.length === 0,
            skills: cleanSkills,
            error: errors.join(", ")
        };
        }

    function renderExperience() {

        let container = $("#p_experience");
        container.html("");

        let type = $("#userType").val();

        // ✅ SHOW TYPE FIRST
        if (type === "fresher") {
            container.append(`
<div style="margin-bottom:10px; font-weight:600; color:#2c3e50;">
    Fresher
</div>
        `);
        }
        else if (type === "experienced") {
            container.append(`
<div style="margin-bottom:10px; font-weight:600; color:#2c3e50;">
    Experienced Professional
</div>
        `);
        }

        // ✅ IF FRESHER → STOP HERE
        if (type === "fresher") {
            return;
        }
        if (type === "experienced" && experiences.length === 0) {
            container.append(`<p>No experience added yet</p>`);
        }

        // ✅ OTHERWISE SHOW EXPERIENCE
        experiences.forEach(exp => {

            let duration = exp.IsCurrent
                ? `${formatDate(exp.StartDate)} - Present`
                : `${formatDate(exp.StartDate)} - ${formatDate(exp.EndDate)}`;

            let desc = exp.Description
                ? exp.Description.split("\n").map(d => d.trim())
                    .filter(d => d.length > 0)
                    .map(d => `<li>${d}</li>`).join("")
                : "";

            container.append(`
<div style="margin-bottom:15px;">
    <div style="display:flex; justify-content:space-between;">
        <b>${exp.JobTitle}</b>
        <span style="font-size:13px;">${duration}</span>
    </div>

    <div style="font-weight:500;">
        ${exp.CompanyName} ${exp.Location ? " - " + exp.Location : ""}
    </div>

    <ul style="margin-top:5px; padding-left:18px;">
        ${desc}
    </ul>
</div>
        `);
        });
    }

    $("#userType").on("change", function () {
        
        renderExperience();
    });

 

</script>